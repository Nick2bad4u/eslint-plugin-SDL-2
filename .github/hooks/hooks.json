{
    "hooks": {
        "sessionEnd": [
            {
                "bash": ".github/hooks/scripts/remove-temp.sh",
                "env": {
                    "SUPPRESS_PWSH_DECORATIONS": "1"
                },
                "powershell": ".github/hooks/scripts/remove-temp.ps1",
                "timeoutSec": 10,
                "type": "command"
            }
        ],
        "sessionStart": [
            {
                "bash": ".github/hooks/scripts/remove-temp.sh",
                "env": {
                    "SUPPRESS_PWSH_DECORATIONS": "1"
                },
                "powershell": ".github/hooks/scripts/remove-temp.ps1",
                "timeoutSec": 10,
                "type": "command"
            }
        ],
        "userPromptSubmitted": [
            {
                "bash": ".github/hooks/scripts/log-prompt.sh",
                "env": {
                    "SUPPRESS_PWSH_DECORATIONS": "1"
                },
                "powershell": ".github/hooks/scripts/log-prompt.ps1",
                "timeoutSec": 10,
                "type": "command"
            }
        ]
    },
    "version": 1
}
